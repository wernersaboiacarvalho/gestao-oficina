<?xml version="1.0" encoding="UTF-8"?>
<feature name="gestao-oficina-mvp" version="1.0" status="fundacao">
  
  <resumo>
    Sistema de Gestão de Oficina - MVP em desenvolvimento.
    Prisma configurado, auth funcionando, estrutura de pastas ok.
    Próximo: criar componentes UI e sidebar.
  </resumo>
  
  <arquivos_principais>
    <arquivo path="prisma/schema.prisma">Schema completo com todas as tabelas</arquivo>
    <arquivo path="src/lib/supabase/client.ts">Supabase client-side</arquivo>
    <arquivo path="src/lib/supabase/server.ts">Supabase server-side</arquivo>
    <arquivo path="src/app/(auth)/login/page.tsx">Página de login</arquivo>
    <arquivo path="src/app/(dashboard)/dashboard/page.tsx">Dashboard</arquivo>
    <arquivo path="src/components/ui/button.tsx">Componente Button</arquivo>
    <arquivo path="middleware.ts">Proteção de rotas</arquivo>
  </arquivos_principais>
  
  <componentes_faltantes>
    <componente>Input</componente>
    <componente>Label</componente>
    <componente>Card (CardHeader, CardTitle, CardDescription, CardContent)</componente>
    <componente>Sidebar</componente>
    <componente>DataTable (para listas)</componente>
  </componentes_faltantes>
  
  <armadilhas>
    <armadilha severidade="alta">
      <problema>Schema duplicado</problema>
      <solucao>Manter apenas prisma/schema.prisma (deletar src/prisma/)</solucao>
    </armadilha>
    <armadilha severidade="alta">
      <problema>Versões incompatíveis Prisma</problema>
      <solucao>Sempre usar mesma versão em prisma e @prisma/client</solucao>
    </armadilha>
    <armadilha severidade="media">
      <problema>Prisma Client sem singleton</problema>
      <solucao>Criar lib/prisma.ts com singleton pattern</solucao>
    </armadilha>
  </armadilhas>

  <ultimaSessao data="2026-04-06">
