      <arquivo>src/app/(auth)/login/page.tsx (novo visual)</arquivo>
      <arquivo>src/app/(auth)/signup/page.tsx (novo visual)</arquivo>
      <arquivo>src/components/layout/sidebar.tsx (visual clean)</arquivo>
