  <!-- ============================================
       BANCO DE DADOS
       ============================================ -->
  <database>
    <schema>
      <!-- Auth & Users -->
      <table name="Profile">
        <field name="id" type="String" pk="true">UUID do Supabase Auth</field>
        <field name="name" type="String"/>
        <field name="role" type="Role" default="MECHANIC">ADMIN | MECHANIC | USER</field>
        <field name="isActive" type="Boolean" default="true"/>
        <relations>serviceOrders (via ServiceOrderMechanic)</relations>
      </table>

      <!-- Clientes & Veículos -->
      <table name="Customer">
        <field name="id" type="String" pk="true"/>
        <field name="name" type="String"/>
        <field name="phone" type="String"/>
        <field name="email" type="String?"/>
        <field name="document" type="String?">CPF ou CNPJ</field>
        <field name="birthday" type="DateTime?"/>
        <relations>vehicles</relations>
      </table>

      <table name="Vehicle">
        <field name="id" type="String" pk="true"/>
        <field name="customerId" type="String" fk="Customer"/>
        <field name="plate" type="String"/>
        <field name="model" type="String"/>
        <field name="brand" type="String"/>
        <field name="year" type="Int?"/>
        <field name="color" type="String?"/>
        <field name="km" type="Int?"/>
        <relations>serviceOrders</relations>
        <note>NÃO possui campo createdAt</note>
      </table>

      <!-- Ordem de Serviço -->
      <table name="ServiceOrder">
        <field name="id" type="String" pk="true"/>
        <field name="vehicleId" type="String" fk="Vehicle"/>
        <field name="status" type="OSStatus" default="OPEN"/>
        <field name="description" type="String">Sintoma relatado</field>
        <field name="isOutsourced" type="Boolean" default="false">Se é terceirizado</field>
        <field name="thirdPartyId" type="String?" fk="ThirdParty"/>
        <field name="totalAmount" type="Decimal" default="0"/>
        <field name="createdAt" type="DateTime"/>
        <field name="updatedAt" type="DateTime"/>
        <relations>mechanics, items, medias</relations>
      </table>

      <table name="ServiceOrderMechanic">
        <field name="id" type="String" pk="true"/>
        <field name="serviceOrderId" type="String" fk="ServiceOrder"/>
        <field name="mechanicId" type="String" fk="Profile"/>
        <note>Permite múltiplos mecânicos por OS</note>
      </table>

      <table name="ServiceOrderItem">
        <field name="id" type="String" pk="true"/>
        <field name="serviceOrderId" type="String" fk="ServiceOrder"/>
        <field name="type" type="ItemType">PART | SERVICE</field>
        <field name="productId" type="String?" fk="Product"/>
        <field name="description" type="String"/>
        <field name="quantity" type="Decimal"/>
        <field name="unitPrice" type="Decimal"/>
      </table>

      <!-- Terceiros -->
      <table name="ThirdParty">
        <field name="id" type="String" pk="true"/>
        <field name="name" type="String"/>
        <field name="phone" type="String?"/>
        <field name="cnpj" type="String?"/>
        <field name="serviceType" type="String?"/>
        <relations>serviceOrders</relations>
      </table>

      <!-- Estoque -->
      <table name="Product">
        <field name="id" type="String" pk="true"/>
        <field name="name" type="String"/>
        <field name="code" type="String?"/>
        <field name="stockQuantity" type="Int" default="0"/>
        <field name="costPrice" type="Decimal"/>
        <field name="salePrice" type="Decimal"/>
        <relations>serviceOrderItems</relations>
      </table>

      <!-- Mídia -->
      <table name="Media">
        <field name="id" type="String" pk="true"/>
        <field name="serviceOrderId" type="String?" fk="ServiceOrder"/>
        <field name="url" type="String"/>
        <field name="type" type="String" default="IMAGE"/>
      </table>
    </schema>

    <enums>
      <enum name="Role">ADMIN, MECHANIC, USER</enum>
      <enum name="OSStatus">ORCAMENTO, OPEN, IN_PROGRESS, WAITING_PARTS_THIRD_PARTY, DONE, BILLED, CANCELLED</enum>
      <enum name="ItemType">PART, SERVICE</enum>
    </enums>
  </database>

