  <!-- ============================================
       PROBLEMAS CONHECIDOS E SOLUÇÕES
       ============================================ -->
  <troubleshooting>
    <category name="Build/Deploy">
      <problem>
        <description>Erro com schema duplicado</description>
        <cause>Dois arquivos schema.prisma (prisma/ e src/prisma/)</cause>
        <solution>Deletar src/prisma/schema.prisma, usar apenas prisma/</solution>
      </problem>
      <problem>
        <description>Incompatibilidade de versões Prisma</description>
        <cause>@prisma/client e prisma em versões diferentes</cause>
        <solution>Sempre manter mesma versão (ex: ambos em 5.22.0)</solution>
      </problem>
    </category>

    <category name="Serialização Server → Client">
      <problem>
        <description>Erro: "Decimal objects are not supported"</description>
        <cause>Decimal do Prisma não é serializável para Client Components</cause>
        <solution>Sempre converter com Number() antes de retornar de Server Actions. Campos afetados: totalAmount, quantity, unitPrice, costPrice, salePrice</solution>
        <exemplo>return { ...order, totalAmount: Number(order.totalAmount) }</exemplo>
      </problem>
      <problem>
        <description>Erro ao passar Date para Client</description>
        <cause>Date não serializa nativamente</cause>
        <solution>Converter com .toISOString() antes de retornar. Campo afetado: birthday</solution>
      </problem>
      <problem>
        <description>Server Action retorna objeto Prisma com Decimal</description>
        <cause>Usar "return prisma.model.create/update/delete(...)" diretamente</cause>
        <solution>Usar await + variável intermediária, converter campos, retornar objeto plain. Para delete sem necessidade de retorno, não usar return.</solution>
      </problem>
    </category>

    <category name="React State">
      <problem>
        <description>Chamar updateItem múltiplas vezes não funciona</description>
        <cause>React agrupa atualizações de estado, aplicando apenas a última</cause>
        <solution>Agrupar todas as atualizações em uma única chamada de setItems com objeto completo</solution>
      </problem>
    </category>

    <category name="UI">
      <problem>
        <description>Input type="number" mostra setas nativas como campo extra no Chrome</description>
        <cause>Spin buttons nativos do browser</cause>
        <solution>CSS: [-moz-appearance:textfield] [&amp;::-webkit-outer-spin-button]:appearance-none [&amp;::-webkit-inner-spin-button]:appearance-none</solution>
      </problem>
    </category>
  </troubleshooting>

  <!-- ============================================
       PADRÕES ESTABELECIDOS
       ============================================ -->
  <patterns>
    <pattern name="Serialização de Server Actions">
      <description>Todas as Server Actions que retornam dados do Prisma devem converter Decimal com Number() e Date com toISOString()</description>
      <example>
        const order = await prisma.serviceOrder.findUnique(...)
        return { ...order, totalAmount: Number(order.totalAmount), createdAt: order.createdAt.toISOString() }
      </example>
    </pattern>
    <pattern name="Delete sem retorno">
      <description>Para operações de delete que não precisam do objeto deletado no client, não usar return</description>
      <example>await prisma.serviceOrder.delete({ where: { id } })</example>
    </pattern>
    <pattern name="Atualização atômica de estado">
      <description>Ao atualizar múltiplos campos de um item no form, fazer em uma única operação de setItems</description>
      <example>
        setItems(prev => {
          const newItems = [...prev]
          newItems[index] = { ...newItems[index], field1: val1, field2: val2 }
          return newItems
        })
      </example>
    </pattern>
    <pattern name="Server components convertem antes de passar para client">
      <description>Páginas server-side devem converter Decimal/Date dos dados do Prisma antes de passar como props para Client Components</description>
    </pattern>
  </patterns>

