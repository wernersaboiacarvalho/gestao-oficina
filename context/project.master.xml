<?xml version="1.0" encoding="UTF-8"?>
<project 
  name="GestaoOficina" 
  version="2.0"
  lastUpdated="2026-04-06"
>

  <!-- ============================================
       VISÃO GERAL
       ============================================ -->
  <overview>
    <description>
      Sistema de gestão para oficinas mecânicas com foco em controle de OS,
      gestão de terceiros, financeiro confiável e UX simplificada.
    </description>
    <businessModel>
      Cliente possui oficina e sofre com sistema atual que não integra terceiros,
      tem relatórios não confiáveis, não permite editar OS e tem UX ruim.
      Werner desenvolve solução completa com Next.js + Supabase.
    </businessModel>
    <owners>
      <owner name="Werner Saboia" role="Desenvolvedor"/>
      <owner name="Dono da Oficina" role="Cliente"/>
    </owners>
  </overview>

  <!-- ============================================
       ARQUITETURA
       ============================================ -->
  <architecture>
    <stack>
      <frontend>Next.js 16, React 19, TypeScript, Tailwind, shadcn/ui (Radix Nova)</frontend>
      <backend>Next.js Server Actions, Prisma ORM</backend>
      <database>PostgreSQL (Supabase)</database>
      <auth>Supabase Auth</auth>
      <storage>Cloudinary (futuro)</storage>
      <notifications>WhatsApp API (futuro)</notifications>
      <deploy>Vercel</deploy>
    </stack>

    <folderStructure>
      <folder path="app/(auth)">Login, signup</folder>
      <folder path="app/(dashboard)">Dashboard principal</folder>
      <folder path="app/(dashboard)/clientes">CRUD de clientes</folder>
      <folder path="app/(dashboard)/veiculos">CRUD de veículos</folder>
      <folder path="app/(dashboard)/os">Ordens de Serviço</folder>
      <folder path="app/(dashboard)/terceiros">CRUD de terceiros</folder>
      <folder path="app/(dashboard)/estoque">Produtos</folder>
      <folder path="app/(dashboard)/relatorios">Relatórios</folder>
      <folder path="actions">Server Actions por feature</folder>
      <folder path="components">Componentes React por feature</folder>
      <folder path="lib">Utilitários, prisma, supabase</folder>
      <folder path="hooks">Custom hooks</folder>
      <folder path="types">TypeScript types</folder>
      <folder path="prisma">Schema e migrations</folder>
    </folderStructure>
  </architecture>

  <!-- ============================================
       FEATURES E STATUS
       ============================================ -->
